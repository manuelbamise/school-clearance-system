generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Department {
  id   String @id @default(cuid())
  name String @unique

  users User[]
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  name         String
  studentId    String?
  staffId      String?
  role         String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
